# ─────────────────────────────────────────────────────────────────────────────
# MAI-Transcribe Demo – environment variables
# Copy this file to `.env` for local development.
# On Azure App Service, set these in Configuration → Application settings.
# ─────────────────────────────────────────────────────────────────────────────

# Azure AI Foundry / Cognitive Services resource URL (no trailing slash)
# Used for the Speech-to-Text (MAI-Transcribe-1.5) REST API.
# Example: https://my-foundry.cognitiveservices.azure.com
SPEECH_ENDPOINT=https://<your-foundry-resource>.cognitiveservices.azure.com

# Azure AI Foundry inference endpoint for the LLM chat-completions API.
# Example: https://my-foundry.services.ai.azure.com/models
FOUNDRY_INFERENCE_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/models

# Comma-separated list of model deployment names to offer for summarisation.
# These must be deployed in your Azure AI Foundry project.
# Example: gpt-5.5,gpt-5.4-nano
AVAILABLE_MODELS=gpt-5.5,gpt-5.4-nano

# ─── Set automatically by Azure App Service ───────────────────────────────────
# PORT is set by App Service; the kit honours it automatically.
# NODE_ENV is set to 'production' by App Service.
# PORT=3000
# NODE_ENV=production

# Disable the kit's built-in HTTP → HTTPS redirect.
# Azure App Service terminates TLS at the platform layer; the Node process
# only ever sees plain HTTP connections. Without this, the kit would
# redirect all traffic in a loop.
USE_HTTPS=false

# ─── Prototype Kit authentication (optional) ─────────────────────────────────
# Set a password to protect the prototype. Leave blank to disable.
# PASSWORD=
